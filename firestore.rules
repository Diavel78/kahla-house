rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: check if the requesting user is an approved admin
    function isAdmin() {
      return request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.approved == true;
    }

    // Helper: check if the requesting user is approved (any role)
    function isApproved() {
      return request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.approved == true;
    }

    // Users collection
    match /users/{userId} {
      // Anyone can create their own user doc (signup)
      allow create: if request.auth != null && request.auth.uid == userId;
      // Users can read their own doc; admins can read all
      allow read: if request.auth != null && (request.auth.uid == userId || isAdmin());
      // Only admins can update/delete user docs
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // Opening lines (odds openers) — authenticated users can read/write
    match /openers/{docId} {
      allow read: if isApproved();
      allow write: if isApproved();
    }

    // Future collections (christmas lists, etc.) go here
  }
}
